---
import Dark from "@dark/DarkModeToggle.astro";
---

<nav class="navbar">
    <div class="menu-toggle" id="menuToggle" aria-label="Abrir menú">
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
    </div>

    <!-- Overlay oscuro para cerrar el menú -->
    <div class="menu-overlay" id="menuOverlay"></div>

    <div
        class="navbar-links gap-4 md:gap-6 flex items-center tracking-wide"
        id="navbarLinks"
        role="navigation"
    >
        <a
            href="#experience"
            class="nav-link mt-2 lato-bold text-lg inline-block border-b-2 border-transparent hover:border-b-gray-400 active:border-b-gray-400 focus:border-b-gray-400 transition-all duration-300"
            >Habilidades</a
        >
        <a
            href="#projects"
            class="nav-link mt-2 lato-bold text-lg inline-block border-b-2 border-transparent hover:border-b-gray-400 active:border-b-gray-400 focus:border-b-gray-400 transition-all duration-300"
            >Proyectos</a
        >
        <a
            href="#contact"
            class="nav-link mt-2 lato-bold text-lg inline-block border-b-2 border-transparent hover:border-b-gray-400 active:border-b-gray-400 focus:border-b-gray-400 transition-all duration-300"
            >Contacto</a
        >
        <div class="mb-2 mt-2 md:mb-0 md:mt-0">
            <Dark />
        </div>
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const menuToggle = document.getElementById("menuToggle");
        const navbarLinks = document.getElementById("navbarLinks");
        const menuOverlay = document.getElementById("menuOverlay");
        const navLinks = document.querySelectorAll(".nav-link");
        const body = document.body;

        // Función para abrir el menú
        const openMenu = () => {
            menuToggle?.classList.add("active");
            navbarLinks?.classList.add("active");
            menuOverlay?.classList.add("active");
            body.style.overflow = "hidden"; // Prevenir scroll
        };

        // Función para cerrar el menú
        const closeMenu = () => {
            menuToggle?.classList.remove("active");
            navbarLinks?.classList.remove("active");
            menuOverlay?.classList.remove("active");
            body.style.overflow = ""; // Restaurar scroll
        };

        // Toggle del menú hamburguesa
        if (menuToggle && navbarLinks) {
            menuToggle.addEventListener("click", () => {
                if (navbarLinks.classList.contains("active")) {
                    closeMenu();
                } else {
                    openMenu();
                }
            });
        }

        // Cerrar al hacer click en el overlay
        menuOverlay?.addEventListener("click", closeMenu);

        // Cerrar al hacer click en cualquier enlace
        navLinks.forEach((link) => {
            link.addEventListener("click", () => {
                // Pequeño delay para que la animación de cierre sea visible
                setTimeout(closeMenu, 100);
            });
        });

        // Cerrar con la tecla Escape
        document.addEventListener("keydown", (e) => {
            if (
                e.key === "Escape" &&
                navbarLinks?.classList.contains("active")
            ) {
                closeMenu();
            }
        });
    });
</script>

<style>
    /* ===== MODO OSCURO ===== */
    body.dark-mode .menu-toggle .line {
        background-color: #fefffa;
    }

    body.dark-mode .menu-toggle:hover .line,
    body.dark-mode .menu-toggle:focus .line {
        background-color: #fefffa;
    }

    @media (max-width: 657px) {
        body.dark-mode .navbar-links {
            background-color: #101820;
            color: #fefffa;
            box-shadow: -4px 0 20px rgba(0, 0, 0, 0.5);
        }

        body.dark-mode .menu-overlay {
            background-color: rgba(0, 0, 0, 0.7);
        }
    }

    body.dark-mode .navbar-links a:hover {
        color: #fefffa;
    }

    /* ===== MENÚ HAMBURGUESA ===== */
    .menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 20px;
        cursor: pointer;
        z-index: 1001;
        position: relative;
        transition: transform 0.3s ease;
    }

    .menu-toggle:hover {
        transform: scale(1.1);
    }

    .menu-toggle:focus {
        outline: 2px solid #4a9eff;
        outline-offset: 4px;
        border-radius: 4px;
    }

    .menu-toggle .line {
        width: 100%;
        height: 3px;
        background-color: #333;
        transition: all 0.3s ease;
        border-radius: 2px;
    }

    /* Animación de la "X" */
    .menu-toggle.active .line:nth-child(1) {
        transform: translateY(8.5px) rotate(45deg);
    }

    .menu-toggle.active .line:nth-child(2) {
        opacity: 0;
        transform: translateX(-10px);
    }

    .menu-toggle.active .line:nth-child(3) {
        transform: translateY(-8.5px) rotate(-45deg);
    }

    /* ===== OVERLAY ===== */
    .menu-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 998;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .menu-overlay.active {
        opacity: 1;
    }

    /* ===== ENLACES DEL MENÚ ===== */
    .navbar-links {
        display: flex;
        align-items: center;
    }

    /* ===== RESPONSIVE MOBILE ===== */
    @media screen and (max-width: 657px) {
        .navbar {
            flex-wrap: wrap;
            justify-content: space-between;
        }

        /* Overlay visible en móvil */
        .menu-overlay {
            display: block;
        }

        .navbar-links {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;
            gap: 0 !important;

            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            width: 75%;
            max-width: 320px;

            background-color: rgba(255, 255, 255, 0.98);
            box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);

            padding: 80px 30px 30px 30px;
            z-index: 999;

            /* Animación desde la derecha */
            transform: translateX(100%);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .navbar-links.active {
            transform: translateX(0);
        }

        /* Estilo de los enlaces en móvil */
        .navbar-links a {
            width: 100%;
            padding: 16px 0;
            margin: 0 !important;
            font-size: 1.25rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
            border-left: 3px solid transparent;
            padding-left: 12px;
            transition: all 0.2s ease;
        }

        .navbar-links a:hover,
        .navbar-links a:focus {
            border-left-color: #4a9eff;
            background-color: rgba(74, 158, 255, 0.05);
            transform: translateX(4px);
        }

        /* Dark mode toggle en móvil */
        .navbar-links > div {
            width: 100%;
            padding: 20px 0;
            margin: 0 !important;
            border-top: 1px solid rgba(0, 0, 0, 0.1);
            margin-top: auto !important;
        }

        body.dark-mode .navbar-links a {
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        body.dark-mode .navbar-links a:hover,
        body.dark-mode .navbar-links a:focus {
            background-color: rgba(74, 158, 255, 0.1);
        }

        body.dark-mode .navbar-links > div {
            border-top-color: rgba(255, 255, 255, 0.1);
        }

        .menu-toggle {
            display: flex;
        }
    }

    /* Animación smooth para el scroll */
    html {
        scroll-behavior: smooth;
    }
</style>
