---

---

<div
    id="projectModal"
    class="fixed inset-0 z-[100] hidden overflow-y-auto"
    aria-labelledby="modal-title"
    role="dialog"
    aria-modal="true"
>
    <!-- Backdrop -->
    <div
        class="fixed inset-0 bg-gray-900/75 backdrop-blur-sm transition-opacity"
        aria-hidden="true"
        id="modalBackdrop"
    >
    </div>

    <div
        class="flex min-h-full items-center justify-center p-4 text-center sm:p-0"
    >
        <div
            class="relative transform overflow-hidden rounded-lg modal-panel text-left shadow-xl sm:my-8 sm:w-full sm:max-w-6xl"
            id="modalContentPanel"
        >
            <!-- Close Button -->
            <button
                type="button"
                id="closeModal"
                class="absolute right-4 top-4 z-10 rounded-full modal-close-btn p-2 hover:opacity-80 focus:outline-none focus:ring-2 focus:ring-white transition-opacity"
            >
                <svg
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <div class="flex flex-col md:flex-row">
                <!-- Image Section -->
                <div
                    class="md:w-3/5 modal-image-section flex items-center justify-center p-0"
                >
                    <img
                        id="modalImage"
                        src=""
                        alt="Project Image"
                        class="w-full h-auto max-h-[90vh] object-contain object-center"
                    />
                </div>

                <!-- Details Section -->
                <div
                    class="md:w-2/5 p-6 sm:p-8 flex flex-col justify-center modal-details"
                >
                    <h3
                        class="text-2xl font-bold leading-6 modal-details-title mb-4 font-lato"
                        id="modalTitle"
                    >
                    </h3>
                    <div class="mt-2">
                        <p
                            class="text-base leading-relaxed font-lato modal-details-desc"
                            id="modalDescription"
                        >
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .modal-panel {
        background: var(--color-bg-light);
        border: 1px solid var(--color-text-light);
    }
    body.dark-mode .modal-panel {
        background: var(--color-bg-dark);
        border: 1px solid #2a3040;
    }

    .modal-image-section {
        background: #f3f4f6;
    }
    body.dark-mode .modal-image-section {
        background: #1a2030;
    }

    .modal-details {
        background: var(--color-bg-light);
        color: var(--color-text-light);
    }
    body.dark-mode .modal-details {
        background: var(--color-bg-dark);
        color: var(--color-text-dark);
        border-left: 1px solid #2a3040;
    }

    .modal-details-title {
        color: var(--color-text-light);
    }
    body.dark-mode .modal-details-title {
        color: var(--color-text-dark);
    }

    .modal-details-desc {
        color: #4b5563;
    }
    body.dark-mode .modal-details-desc {
        color: #d1d5db;
    }

    .modal-close-btn {
        background: rgba(0, 0, 0, 0.1);
        color: var(--color-text-light);
    }
    body.dark-mode .modal-close-btn {
        background: rgba(255, 255, 255, 0.12);
        color: var(--color-text-dark);
    }

    @media (max-width: 767px) {
        .modal-details {
            border-left: none;
            border-top: 1px solid var(--color-text-light);
        }
        body.dark-mode .modal-details {
            border-top: 1px solid #2a3040;
        }
    }
</style>

<script>
    import { gsap } from "gsap";

    const modal = document.getElementById("projectModal");
    const backdrop = document.getElementById("modalBackdrop");
    const closeBtn = document.getElementById("closeModal");
    const contentPanel = document.getElementById("modalContentPanel");
    const modalImage = document.getElementById("modalImage") as HTMLImageElement | null;
    const modalTitle = document.getElementById("modalTitle");
    const modalDescription = document.getElementById("modalDescription");
    const imageSection = document.querySelector(".modal-image-section");
    const detailsSection = document.querySelector(".modal-details");

    let openTl: gsap.core.Timeline | null = null;
    let closeTl: gsap.core.Timeline | null = null;

    function openModal(fullImageUrl: string, title: string, description: string) {
        if (!modal || !modalImage || !modalTitle || !modalDescription || !contentPanel || !imageSection || !detailsSection) return;

        closeTl?.kill();

        modalImage.src = fullImageUrl;
        modalTitle.textContent = title;
        modalDescription.textContent = description;

        modal.classList.remove("hidden");

        gsap.set(backdrop, { autoAlpha: 0 });
        gsap.set(contentPanel, { opacity: 0, scale: 0.92 });
        gsap.set(imageSection, { x: -30, opacity: 0 });
        gsap.set(detailsSection, { x: 30, opacity: 0 });
        gsap.set(closeBtn, { rotation: -90, opacity: 0 });

        document.body.style.overflow = "hidden";

        openTl = gsap.timeline()
            .to(backdrop, { autoAlpha: 1, duration: 0.5, ease: "power2.out" })
            .to(contentPanel, { opacity: 1, scale: 1, duration: 0.6, ease: "back.out(1.5)" }, "-=0.25")
            .to(imageSection, { x: 0, opacity: 1, duration: 0.55, ease: "power2.out" }, "-=0.4")
            .to(detailsSection, { x: 0, opacity: 1, duration: 0.55, ease: "power2.out" }, "-=0.5")
            .to(closeBtn, { rotation: 0, opacity: 1, duration: 0.5, ease: "back.out(1.4)" }, "-=0.35");
    }

    function closeModal() {
        if (!modal || !contentPanel || !imageSection || !detailsSection) return;

        openTl?.kill();

        closeTl = gsap.timeline({
            onComplete: () => {
                modal.classList.add("hidden");
                if (modalImage) modalImage.src = "";
                if (modalTitle) modalTitle.textContent = "";
                if (modalDescription) modalDescription.textContent = "";
                document.body.style.overflow = "";
            },
        });

        closeTl
            .to(closeBtn, { rotation: -90, opacity: 0, duration: 0.3, ease: "power2.in" })
            .to([imageSection, detailsSection], { opacity: 0, duration: 0.35, ease: "power2.in" }, "-=0.15")
            .to(contentPanel, { opacity: 0, scale: 0.95, duration: 0.35, ease: "power2.in" }, "-=0.15")
            .to(backdrop, { autoAlpha: 0, duration: 0.3, ease: "power2.in" }, "-=0.2");
    }

    document.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest(".project-item");
        if (!target) return;

        if (target.tagName === "A" && target.getAttribute("target") === "_blank") {
            return;
        }

        const fullImage = target.getAttribute("data-full-image");
        const title = target.getAttribute("data-project-title");
        const description = target.getAttribute("data-project-description");

        if (fullImage && title && description) {
            e.preventDefault();
            openModal(fullImage, title, description);
        }
    });

    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal?.classList.contains("hidden")) {
            closeModal();
        }
    });
</script>