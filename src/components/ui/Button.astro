---
interface Props {
    href: string;
    variant?: "primary" | "outline";
    download?: boolean;
    class?: string;
    id?: string;
}

const {
    href,
    variant = "primary",
    download = false,
    class: className = "",
    id,
} = Astro.props;
---

<a
    href={href}
    class:list={[
        variant === "primary"
            ? "inline-flex items-center justify-center cursor-pointer select-none no-underline touch-manipulation rounded-none border-0 box-border max-w-full whitespace-nowrap min-w-[140px] md:min-w-[196px] text-[20px] md:text-[24px] leading-[1em] px-6 py-4 boton-cv transition-all duration-300 hover:scale-105"
            : "boton",
        className
    ]}
    download={download ? "" : undefined}
    id={id}
>
    <span class="lato-regular">
        <slot />
    </span>
</a>

<style>
    .boton-cv {
        background-color: var(--color-bg-dark);
        color: var(--color-text-dark);
        box-shadow: 0 4px 14px rgba(16, 24, 32, 0.15);
    }

    .boton-cv:hover {
        box-shadow: 0 10px 30px -5px rgba(16, 24, 32, 0.35);
    }

    :global(body.dark-mode) .boton-cv {
        background-color: var(--color-bg-light);
        color: var(--color-text-light);
        box-shadow: 0 4px 14px rgba(254, 255, 250, 0.1);
    }

    :global(body.dark-mode) .boton-cv:hover {
        box-shadow: 0 10px 30px -5px rgba(254, 255, 250, 0.2);
    }

    .boton {
        align-items: center;
        background-color: #fefffa;
        border-radius: 0px;
        box-shadow:
            transparent 0 0 0 3px,
            rgba(16, 24, 32, 0.1) 0 6px 20px;
        box-sizing: border-box;
        color: #101820;
        cursor: pointer;
        display: inline-flex;
        flex: 1 1 auto;
        font-size: 1.2rem;
        font-weight: 700;
        justify-content: center;
        line-height: 1;
        margin: 0;
        outline: none;
        padding: 1.2rem 1.44rem;
        text-align: center;
        text-decoration: none;
        transition:
            box-shadow 0.2s,
            -webkit-box-shadow 0.2s;
        white-space: nowrap;
        border: 0;
        user-select: none;
        -webkit-user-select: none;
        touch-action: manipulation;
    }

    .boton:hover {
        box-shadow:
            #101820 0 0 0 3px,
            transparent 0 0 0 0;
    }

    :global(body.dark-mode) .boton {
        background-color: #101820;
        box-shadow:
            transparent 0 0 0 3px,
            rgba(254, 255, 250, 0.1) 0 6px 20px;
        color: #fefffa;
    }

    :global(body.dark-mode) .boton:hover {
        box-shadow:
            #fefffa 0 0 0 3px,
            transparent 0 0 0 0;
    }
</style>
